<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Deployments</title>
  <link rel="icon" type="image/png" href="/mottzi.png">
  <link rel="stylesheet" href="/deployer.css">
</head>
<body>

  <div class="dp-shell">

    <!-- ── Header ──────────────────────────────────────────── -->
    <header class="dp-header">
      <div class="dp-header-inner">

        <div class="dp-wordmark">
          <div class="dp-wordmark-icon">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 1L12.5 4.25V10.75L7 14L1.5 10.75V4.25L7 1Z" stroke="white" stroke-width="1.2" stroke-linejoin="round"/>
              <circle cx="7" cy="7" r="2" fill="white"/>
            </svg>
          </div>
          <span class="dp-wordmark-title">Deployer</span>
        </div>

        <div class="dp-header-right">

          <div
            class="dp-status-slot"
            mist-container="DeploymentStatus"
            mist-insert-position="beforeend"
          >
            #if(component):
              #extend("Deployer/DeploymentStatus")
            #endif
          </div>

          <form class="dp-logout-form" method="POST" action="/deployer/logout">
            <button type="submit" class="dp-logout-btn" title="Logout">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
              </svg>
            </button>
          </form>

        </div>

      </div>
    </header>

    <!-- ── Main ────────────────────────────────────────────── -->
    <main class="dp-main">

      #for(table in tables):
      <section class="dp-section">

        <!-- Section header -->
        <div class="dp-section-header">
          <span class="dp-section-prompt">
            <span class="dp-section-prompt-symbol">~/</span>#(table.productName)
          </span>

          <div
            class="dp-supervisor-slot"
            mist-container="ProductStatus-#(table.productName)"
            mist-insert-position="beforeend"
          >
            #if(table.productStatus):
              <div class="dp-product-status" mist-component="ProductStatus-#(table.productStatus.productstatus.productName)">
                #if(table.productStatus.productstatus.isRunning):
                  <span class="dp-supervisor-badge dp-supervisor-badge--running">
                    <span class="dp-supervisor-dot"></span>running
                  </span>
                  <button class="dp-supervisor-btn dp-supervisor-btn--stop" mist-action="stop">stop</button>
                #else:
                  <span class="dp-supervisor-badge dp-supervisor-badge--stopped">
                    <span class="dp-supervisor-dot"></span>stopped
                  </span>
                #endif
                <button class="dp-supervisor-btn dp-supervisor-btn--restart" mist-action="restart">restart</button>
              </div>
            #endif
          </div>
        </div>

        <!-- Table card -->
        <div class="dp-card">
          <div class="dp-table-wrap">
            <table class="dp-table">

              <thead
                class="dp-thead"
                mist-container="DeploymentRow-#(table.productName)"
                mist-insert-position="afterend"
              >
                <tr>
                  <th class="dp-th">Status</th>
                  <th class="dp-th">Commit</th>
                  <th class="dp-th dp-th-sm-hide">Mode</th>
                  <th class="dp-th dp-th-sm-hide">ID</th>
                  <th class="dp-th dp-th-sm-hide">Started</th>
                  <th class="dp-th">Duration</th>
                  <th class="dp-th"></th>
                </tr>
              </thead>

              #for(component in table.rows):
                #extend("Deployer/DeploymentRow")
              #endfor

            </table>
          </div>
        </div>

      </section>
      #endfor

    </main>

  </div>

  <script src="/morphdom.js"></script>
  <script src="/mist.js" data-url="/deployer/ws/"></script>

</body>
</html>
