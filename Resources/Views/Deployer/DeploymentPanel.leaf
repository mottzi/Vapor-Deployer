<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Deployments</title>
  <link rel="icon" type="image/png" href="/mottzi.png">
  <link rel="stylesheet" href="/deployer.css">
</head>
<body>

  <div class="dp-shell">

    <!-- ── Header ──────────────────────────────────────────── -->
    <header class="dp-header">
      <div class="dp-header-inner">

        <div class="dp-wordmark">
          <div class="dp-wordmark-icon">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 1L12.5 4.25V10.75L7 14L1.5 10.75V4.25L7 1Z" stroke="white" stroke-width="1.2" stroke-linejoin="round"/>
              <circle cx="7" cy="7" r="2" fill="white"/>
            </svg>
          </div>
          <span class="dp-wordmark-title">Deployer</span>
        </div>

        <div
          class="dp-status-slot"
          mist-container="DeploymentStatus"
          mist-insert-position="beforeend"
        >
          #if(component):
            #extend("Deployer/DeploymentStatus")
          #endif
        </div>

      </div>
    </header>

    <!-- ── Main ────────────────────────────────────────────── -->
    <main class="dp-main">

      #for(table in tables):
      <section class="dp-section">

        <!-- Section header -->
        <div class="dp-section-header">
          <span class="dp-section-prompt">
            <span class="dp-section-prompt-symbol">~/</span>#(table.productName)
          </span>
          <div class="dp-section-line"></div>
          <span class="dp-section-title">#(table.title)</span>
        </div>

        <!-- Table card -->
        <div class="dp-card">
          <div class="dp-table-wrap">
            <table class="dp-table">

              <thead
                class="dp-thead"
                mist-container="DeploymentRow-#(table.productName)"
                mist-insert-position="afterend"
              >
                <tr>
                  <th class="dp-th">Status</th>
                  <th class="dp-th">Commit</th>
                  <th class="dp-th dp-th-sm-hide">Mode</th>
                  <th class="dp-th dp-th-sm-hide">ID</th>
                  <th class="dp-th dp-th-sm-hide">Started</th>
                  <th class="dp-th">Duration</th>
                  <th class="dp-th"></th>
                </tr>
              </thead>

              #for(component in table.rows):
                #extend("Deployer/DeploymentRow")
              #endfor

            </table>
          </div>
        </div>

      </section>
      #endfor

    </main>

  </div>

  <script src="/morphdom.js"></script>
  <script src="/mist.js" data-url="/deployer/ws/"></script>

</body>
</html>
