<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Deployer</title>
  <link rel="icon" type="image/png" href="#(deployer.panelRoute)/mottzi.png">
  <link rel="stylesheet" href="#(deployer.panelRoute)/deployer.css">
</head>
<body>

  <div class="dp-shell">
    <div class="dp-page">
      <main class="dp-main">
        <section class="dp-target-section">

          <div class="dp-workspace">
            <header class="dp-header-panel" aria-label="Deployer">
            <!-- ── Runtime bar: logo · metadata strip · sign out ── -->
            <div class="dp-runtime-bar" aria-label="Deployer runtime">

              <div class="dp-runtime-brand">
                <h1 class="dp-runtime-brand-title">
                  <a class="dp-wordmark" href="#(deployer.repositoryWebPageURL)" target="_blank" rel="noopener noreferrer">
                    <img class="dp-wordmark-image" src="#(deployer.panelRoute)/mottzi.png" alt="" width="32" height="32">
                    <span class="dp-wordmark-title">Deployer</span>
                  </a>
                </h1>
                <!-- On mobile, sign-out moves inside brand row via CSS order -->
                <div class="dp-runtime-actions dp-runtime-actions--mobile">
                  <form class="dp-logout-form" method="POST" action="#(deployer.panelRoute)/logout">
                    <button type="submit" class="dp-logout-btn" title="Sign out">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                      </svg>
                      Sign out
                    </button>
                  </form>
                </div>
              </div>

              <div
                class="dp-runtime-queue-slot"
                mist-container="QueueComponent"
                mist-insert-position="beforeend"
              >
                #if(target.queueIsDeploying):
                  <span
                    class="dp-supervisor-badge dp-supervisor-badge--queue-locked"
                    mist-component="QueueComponent"
                    title="Queue locked — deployment in progress"
                    aria-label="Queue locked — deployment in progress"
                  >
                    Locked
                  </span>
                #else:
                  <span
                    class="dp-supervisor-badge dp-supervisor-badge--queue-unlocked"
                    mist-component="QueueComponent"
                    title="Queue unlocked — ready"
                    aria-label="Queue unlocked — ready"
                  >
                    Unlocked
                  </span>
                #endif
              </div>

              <div class="dp-runtime-items">
                <div class="dp-context-item dp-context-item--version">
                  <span class="dp-context-label">Version</span>
                  <span class="dp-context-value">#(deployer.version)</span>
                </div>
                <div class="dp-context-item dp-context-item--port">
                  <span class="dp-context-label">Port</span>
                  <span class="dp-context-value">#(deployer.port)</span>
                </div>
                <div class="dp-context-item dp-context-item--deployerdir">
                  <span class="dp-context-label">Directory</span>
                  <span class="dp-context-value" title="#(deployer.deployerDirectory)">#(deployer.deployerDirectory)</span>
                </div>
                <div class="dp-context-item dp-context-item--socket">
                  <span class="dp-context-label">Socket</span>
                  <span class="dp-context-value">#(deployer.mistSocket)</span>
                </div>
                <div class="dp-context-item dp-context-item--route">
                  <span class="dp-context-label">Route</span>
                  <span class="dp-context-value">#(deployer.panelRoute)</span>
                </div>
              </div>

              <!-- Desktop sign-out (hidden on mobile) -->
              <div class="dp-runtime-actions dp-runtime-actions--desktop">
                <form class="dp-logout-form" method="POST" action="#(deployer.panelRoute)/logout">
                  <button type="submit" class="dp-logout-btn" title="Sign out">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                      <polyline points="16 17 21 12 16 7"/>
                      <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Sign out
                  </button>
                </form>
              </div>

            </div>
            <!-- /runtime bar -->
            </header>

            <div class="dp-target-panel">
            <!-- ── Target toolbar: name · status · config · stop · restart ── -->
            <div class="dp-runtime-bar">
              <!-- Left: app name + running badge -->
              <div class="dp-runtime-brand">
                <h2 class="dp-target-name">#(target.name)</h2>
                <div
                  class="dp-status-badge-slot"
                  mist-container="StatusComponent-#(target.name)"
                  mist-insert-position="beforeend"
                >
                  <div class="dp-product-status" mist-component="StatusComponent-#(target.name)">
                    #if(target.isRunning):
                      <span class="dp-supervisor-badge dp-supervisor-badge--running">running</span>
                    #else:
                      <span class="dp-supervisor-badge dp-supervisor-badge--stopped">stopped</span>
                    #endif
                  </div>
                </div>
              </div>

              <!-- Center: Configuration items -->
              <div
                class="dp-runtime-items"
                mist-container="#(target.configComponentName)"
                mist-insert-position="beforeend"
              >
                #unsafeHTML(target.configInitialHTML)
              </div>

              <!-- Right: stop + restart -->
              <div class="dp-runtime-actions dp-runtime-actions--desktop">
                <div class="dp-target-actions">
                  #if(target.isRunning):
                    <button
                      class="dp-supervisor-btn dp-supervisor-btn--stop"
                      mist-action="stop"
                      mist-actions-for="StatusComponent-#(target.name)"
                      title="Stop service"
                    >
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <rect x="4" y="4" width="16" height="16" rx="2"/>
                      </svg>
                      Stop
                    </button>
                  #endif
                  <button
                    class="dp-supervisor-btn dp-supervisor-btn--restart"
                    mist-action="restart"
                    mist-actions-for="StatusComponent-#(target.name)"
                    title="Restart service"
                  >
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                      <path d="M3 3v5h5"/>
                    </svg>
                    Restart
                  </button>
                </div>
              </div>
            </div>
            <!-- /target toolbar -->

            <!-- ── Deployments Table ── -->
            <div class="dp-deployments">
              <div class="dp-table-wrap">
                <table
                  class="dp-table"
                  mist-behavior="sortable-collection"
                  data-mist-sort-order="desc"
                  data-mist-sort-type="number"
                  data-mist-sort-delay-ms="1000"
                >
                  <thead
                    class="dp-thead"
                    mist-container="RowComponent-#(target.name)"
                    mist-insert-position="afterend"
                  >
                    <tr>
                      <th class="dp-th dp-th-status">Status</th>
                      <th class="dp-th dp-th-commit">Commit</th>
                      <th class="dp-th dp-th-sm-hide dp-th-mobile-hide">ID</th>
                      <th class="dp-th dp-th-started">Started</th>
                      <th class="dp-th dp-th-duration dp-th-mobile-hide">Duration</th>
                      <th class="dp-th dp-th-action">Actions</th>
                    </tr>
                  </thead>

                  #for(context in target.rows):
                    #extend("Deployer/RowComponent")
                  #endfor

                </table>
              </div>
            </div>

            </div>
            <!-- /target-panel -->
          </div>
          <!-- /workspace -->

          <!-- Status legend -->
          <div class="dp-legend">
            <span class="dp-legend-item">
              <span class="dp-legend-dot" style="background:var(--c-pushed)"></span>
              <span class="dp-legend-label">pushed</span>
            </span>
            <span class="dp-legend-item">
              <span class="dp-legend-dot" style="background:var(--c-running)"></span>
              <span class="dp-legend-label">running</span>
            </span>
            <span class="dp-legend-item">
              <span class="dp-legend-dot" style="background:var(--c-success)"></span>
              <span class="dp-legend-label">success</span>
            </span>
            <span class="dp-legend-item">
              <span class="dp-legend-dot" style="background:var(--c-deployed)"></span>
              <span class="dp-legend-label">deployed</span>
            </span>
            <span class="dp-legend-item">
              <span class="dp-legend-dot" style="background:var(--c-failed)"></span>
              <span class="dp-legend-label">failed</span>
            </span>
            <span class="dp-legend-item">
              <span class="dp-legend-dot" style="background:var(--c-canceled)"></span>
              <span class="dp-legend-label">canceled</span>
            </span>
            <span class="dp-legend-item">
              <span class="dp-legend-dot" style="background:var(--c-stale)"></span>
              <span class="dp-legend-label">stale</span>
            </span>
          </div>

        </section>
      </main>
    </div>
  </div>

  <script src="#(deployer.panelRoute)/morphdom.js"></script>
  <script src="#(deployer.panelRoute)/mist.js" data-url="#(deployer.panelRoute)/ws"></script>
  <script>
    (function () {
      document.body.addEventListener('click', function (e) {
        var sum = e.target.closest('.dp-target-toolbar-summary');
        if (!sum || !sum.contains(e.target)) return;
        if (
          e.target.closest('.dp-target-name') ||
          e.target.closest('.dp-status-badge-slot')
        ) {
          e.preventDefault();
          e.stopPropagation();
        }
      }, true);
    })();
  </script>

</body>
</html>
