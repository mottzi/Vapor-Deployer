<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Deployments</title>
  <link rel="icon" type="image/png" href="/deployer/mottzi.png">
  <link rel="stylesheet" href="/deployer/deployer.css">
</head>
<body>

  <div class="dp-shell">

    <!-- ── Header ──────────────────────────────────────────── -->
    <header class="dp-header">
      <div class="dp-header-inner">

        <div class="dp-wordmark">
          <img class="dp-wordmark-image" src="/deployer/mottzi.png" alt="Mottzi icon" width="28" height="28">
          <span class="dp-wordmark-title">
            Deployer TEST 4133
          </span>
        </div>

        <div class="dp-header-right">

          <form class="dp-logout-form" method="POST" action="/deployer/logout">
            <button type="submit" class="dp-logout-btn" title="Logout">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
              </svg>
            </button>
          </form>

        </div>

      </div>
    </header>

    <!-- ── Main ────────────────────────────────────────────── -->
    <main class="dp-main">

      #for(table in tables):
      <section class="dp-section">

        <!-- Section header -->
        <div class="dp-section-header">
          <span class="dp-section-prompt">
            <span class="dp-section-prompt-symbol">~/</span>#(table.productName)
          </span>
          <div class="dp-info-overlay">
            <span class="dp-info-trigger" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M12 11v5"></path>
                <path d="M12 8h.01"></path>
              </svg>
            </span>
            <div
              class="dp-info-popover"
              id="#(table.configPopover.componentName)"
            >
              <div
                class="dp-info-popover-slot"
                mist-container="#(table.configPopover.componentName)"
                mist-insert-position="beforeend"
              >
                #unsafeHTML(table.configPopover.initialHTML)
              </div>
            </div>
          </div>
          #if(table.showsQueueState):
            <div
              class="dp-queue-lock-slot"
              mist-container="QueueComponent"
              mist-insert-position="beforeend"
            >
              #if(table.queueIsDeploying):
                <span
                  class="dp-queue-lock dp-queue-lock--locked"
                  mist-component="QueueComponent"
                  title="Deployment queue locked: a deployment is in progress."
                  aria-label="Deployment queue locked: a deployment is in progress."
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="5" y="11" width="14" height="10" rx="2"></rect>
                    <path d="M8 11V8a4 4 0 0 1 8 0v3"></path>
                  </svg>
                  <span class="dp-visually-hidden">Locked</span>
                </span>
              #else:
                <span
                  class="dp-queue-lock dp-queue-lock--unlocked"
                  mist-component="QueueComponent"
                  title="Deployment queue unlocked: ready for a new deployment."
                  aria-label="Deployment queue unlocked: ready for a new deployment."
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="5" y="11" width="14" height="10" rx="2"></rect>
                    <path d="M8 11V8a4 4 0 0 1 7-2.8"></path>
                    <path d="M15 8l2.5-2.5"></path>
                  </svg>
                  <span class="dp-visually-hidden">Unlocked</span>
                </span>
              #endif
            </div>
          #endif
          <div class="dp-section-spacer"></div>
          <div
            class="dp-supervisor-slot"
            mist-container="StatusComponent-#(table.productName)"
            mist-insert-position="beforeend"
          >
            <div class="dp-product-status" mist-component="StatusComponent-#(table.productName)">
              #if(table.isRunning):
                <button class="dp-supervisor-btn dp-supervisor-btn--stop" mist-action="stop" title="Stop">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                    <rect x="4" y="4" width="16" height="16" rx="2"/>
                  </svg>
                </button>
              #endif

              <button class="dp-supervisor-btn dp-supervisor-btn--restart" mist-action="restart" title="Restart">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                  <polyline points="23 4 23 10 17 10"/>
                  <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
                </svg>
              </button>

              #if(table.isRunning):
                <span class="dp-supervisor-badge dp-supervisor-badge--running">
                  <span class="dp-supervisor-dot"></span>running
                </span>
              #else:
                <span class="dp-supervisor-badge dp-supervisor-badge--stopped">
                  <span class="dp-supervisor-dot"></span>stopped
                </span>
              #endif
            </div>
          </div>
        </div>

        <!-- Table card -->
        <div class="dp-card">
          <div class="dp-table-wrap">
            <table
              class="dp-table"
              mist-behavior="sortable-collection"
              data-mist-sort-order="desc"
              data-mist-sort-type="number"
              data-mist-sort-delay-ms="1000"
            >

              <thead
                class="dp-thead"
                mist-container="RowComponent-#(table.productName)"
                mist-insert-position="afterend"
              >
                <tr>
                  <th class="dp-th dp-th-status">Status</th>
                  <th class="dp-th dp-th-commit">Commit</th>
                  <th class="dp-th dp-th-sm-hide dp-th-mobile-hide">ID</th>
                  <th class="dp-th dp-th-started">Started</th>
                  <th class="dp-th dp-th-duration dp-th-mobile-hide">Duration</th>
                  <th class="dp-th dp-th-action"></th>
                </tr>
              </thead>

              #for(context in table.rows):
                #extend("Deployer/RowComponent")
              #endfor

            </table>
          </div>
        </div>

      </section>
      #endfor
      
      <!-- ── Status Legend ──────────────────────────────────── -->
      <div class="dp-legend">
        <span class="dp-legend-item">
          <span class="dp-legend-dot" style="background:var(--c-pushed)"></span>
          <span class="dp-legend-label">pushed</span>
        </span>
        <span class="dp-legend-item">
          <span class="dp-legend-dot" style="background:var(--c-running)"></span>
          <span class="dp-legend-label">running</span>
        </span>
        <span class="dp-legend-item">
          <span class="dp-legend-dot" style="background:var(--c-success)"></span>
          <span class="dp-legend-label">success</span>
        </span>
        <span class="dp-legend-item">
          <span class="dp-legend-dot" style="background:var(--c-deployed)"></span>
          <span class="dp-legend-label">deployed</span>
        </span>
        <span class="dp-legend-item">
          <span class="dp-legend-dot" style="background:var(--c-failed)"></span>
          <span class="dp-legend-label">failed</span>
        </span>
        <span class="dp-legend-item">
          <span class="dp-legend-dot" style="background:var(--c-canceled)"></span>
          <span class="dp-legend-label">canceled</span>
        </span>
        <span class="dp-legend-item">
          <span class="dp-legend-dot" style="background:var(--c-stale)"></span>
          <span class="dp-legend-label">stale</span>
        </span>
      </div>

    </main>

  </div>

  <script src="/deployer/morphdom.js"></script>
  <script src="/deployer/mist.js" data-url="/deployer/ws"></script>

</body>
</html>
